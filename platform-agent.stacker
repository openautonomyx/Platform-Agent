# Platform Agent - Stacker Build

name: platform-agent
description: Platform Agent with SurrealDB backend

# Build stage - compile Python
build-platform-agent:
  from: docker://python:3.12-slim
  build_only: true
  import: .
    - ./src
    - ./pyproject.toml
  run: |
    pip install --no-cache-dir surrealdb aiohttp pydantic
    pip install -e /stacker/.

# Runtime stage
platform-agent:
  from: docker://python:3.12-slim
  import:
    - stacker://build-platform-agent
  run: |
    cp /stacker/src/* /app/src/
    cp /stacker/pyproject.toml /app/
    pip install --no-cache-dir surrealdb aiohttp pydantic uvicorn fastapi
    pip install -e /app/
    EXPORT 3000
    CMD ["uvicorn", "platform_agent.server:app", "--host", "0.0.0.0"]

# UI build stage
build-ui:
  from: docker://node:20-slim
  build_only: true
  import:
    - ./ui
  run: |
    cd /stacker/ui
    npm install
    npm run build

# UI runtime
ui:
  from: docker://nginx:alpine
  import:
    - stacker://build-ui/dist
  run: |
    cp -r /stacker/dist/* /usr/share/nginx/html/
    EXPORT 4321
    CMD ["nginx", "-g", "daemon off;"]