---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Platform Agent</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-gray-950 text-white h-screen overflow-hidden flex">
    <!-- Sidebar -->
    <nav class="w-16 bg-gray-900 flex flex-col items-center py-4 gap-2">
      <a href="/" class="p-3 rounded-lg hover:bg-gray-800" title="Home">🏠</a>
      <a href="/chat" class="p-3 rounded-lg bg-gray-800" title="Chat">💬</a>
      <a href="/graph" class="p-3 rounded-lg hover:bg-gray-800" title="Graph">🔗</a>
      <a href="/canvas" class="p-3 rounded-lg hover:bg-gray-800" title="Canvas">🎨</a>
      <div class="flex-1"></div>
      <a href="/settings" class="p-3 rounded-lg hover:bg-gray-800" title="Settings">⚙️</a>
      <a href="/profile" class="p-3 rounded-lg hover:bg-gray-800" title="Profile">👤</a>
      <a href="/organization" class="p-3 rounded-lg hover:bg-gray-800" title="Org">🏢</a>
    </nav>
    <main class="flex-1 overflow-hidden">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import "tailwindcss";
  
  :root {
    --color-cyan: #06b6d4;
    --color-blue: #3b82f6;
  }
  
  * {
    scrollbar-width: thin;
    scrollbar-color: #374151 #1f2937;
  }
  
  *::-webkit-scrollbar {
    width: 6px;
  }
  
  *::-webkit-scrollbar-track {
    background: #1f2937;
  }
  
  *::-webkit-scrollbar-thumb {
    background: #374151;
    border-radius: 3px;
  }
</style>