---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Platform Agent</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-gray-950 text-white h-screen overflow-hidden flex flex-col">
    <!-- Main Nav -->
    <nav class="border-b border-gray-800 px-4 py-2 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="text-lg font-bold">🤖</a>
        <div class="flex gap-1 text-sm text-gray-400">
          <a href="/" class="px-3 py-1 rounded-lg bg-gray-800">💬 Chat</a>
          <a href="/graph" class="px-3 py-1 rounded-lg hover:bg-gray-800">🔗</a>
          <a href="/canvas" class="px-3 py-1 rounded-lg hover:bg-gray-800">🎨</a>
        </div>
      </div>
      <div class="flex gap-1 text-gray-400">
        <a href="/settings" class="px-2 py-1 rounded-lg hover:bg-gray-800" title="Settings">⚙️</a>
        <a href="/profile" class="px-2 py-1 rounded-lg hover:bg-gray-800" title="Profile">👤</a>
        <a href="/organization" class="px-2 py-1 rounded-lg hover:bg-gray-800" title="Org">🏢</a>
      </div>
    </nav>
    <div class="flex-1 flex overflow-hidden">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @import "tailwindcss";
  
  :root {
    --color-cyan: #06b6d4;
    --color-blue: #3b82f6;
  }
  
  * {
    scrollbar-width: thin;
    scrollbar-color: #374151 #1f2937;
  }
  
  *::-webkit-scrollbar {
    width: 6px;
  }
  
  *::-webkit-scrollbar-track {
    background: #1f2937;
  }
  
  *::-webkit-scrollbar-thumb {
    background: #374151;
    border-radius: 3px;
  }
</style>