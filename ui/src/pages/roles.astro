---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Roles | Platform Agent">
  <div class="max-w-4xl mx-auto py-8">
    <h1 class="text-3xl font-bold mb-8">👥 Roles & Permissions</h1>
    
    <!-- Role Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      
      <!-- Admin -->
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">👑</span>
            <h3 class="text-lg font-semibold">Admin</h3>
          </div>
          <span class="px-2 py-1 bg-red-100 text-red-700 rounded text-sm">Owner</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">Full access to all features and settings</p>
        <ul class="text-sm space-y-1">
          <li>✓ Manage billing</li>
          <li>✓ Access all data</li>
          <li>✓ Add/remove users</li>
          <li>✓ Change settings</li>
          <li>✓ Delete workspace</li>
        </ul>
      </div>
      
      <!-- Editor -->
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">✏️</span>
            <h3 class="text-lg font-semibold">Editor</h3>
          </div>
          <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded text-sm">Write</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">Can edit content and manage conversations</p>
        <ul class="text-sm space-y-1">
          <li>✓ Chat with agent</li>
          <li>✓ Create conversations</li>
          <li>✓ Edit knowledge base</li>
          <li>✓ Use API</li>
          <li>✗ Manage billing</li>
        </ul>
      </div>
      
      <!-- Viewer -->
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">👁️</span>
            <h3 class="text-lg font-semibold">Viewer</h3>
          </div>
          <span class="px-2 py-1 bg-green-100 text-green-700 rounded text-sm">Read</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">Read-only access to conversations</p>
        <ul class="text-sm space-y-1">
          <li>✓ Chat with agent</li>
          <li>✓ View history</li>
          <li>✓ Export data</li>
          <li>✗ Edit content</li>
          <li>✗ Manage users</li>
        </ul>
      </div>
      
      <!-- API User -->
      <div class="card">
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🔌</span>
            <h3 class="text-lg font-semibold">API User</h3>
          </div>
          <span class="px-2 py-1 bg-purple-100 text-purple-700 rounded text-sm">Token</span>
        </div>
        <p class="text-sm text-gray-600 mb-4">Programmatic access via API keys</p>
        <ul class="text-sm space-y-1">
          <li>✓ Use REST API</li>
          <li>✓ Webhook calls</li>
          <li>✓ Read/write data</li>
          <li>✗ UI access</li>
          <li>✗ Admin</li>
        </ul>
      </div>
    </div>
    
    <!-- Team Members -->
    <section class="card mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">Team Members</h2>
        <button id="inviteBtn" class="btn-primary">
          ➕ Invite
        </button>
      </div>
      
      <table class="w-full">
        <thead>
          <tr class="text-left text-sm text-gray-500 border-b">
            <th class="pb-2">User</th>
            <th class="pb-2">Role</th>
            <th class="pb-2">Status</th>
            <th class="pb-2">Actions</th>
          </tr>
        </thead>
        <tbody id="membersList">
          <tr class="border-b">
            <td class="py-3 flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-blue-500 text-white flex items-center justify-center">Y</div>
              <div>
                <div class="font-medium">You</div>
                <div class="text-xs text-gray-500">you@example.com</div>
              </div>
            </td>
            <td class="py-3">
              <select class="input py-1">
                <option selected>Admin</option>
                <option>Editor</option>
                <option>Viewer</option>
              </select>
            </td>
            <td class="py-3">
              <span class="text-green-600">Active</span>
            </td>
            <td class="py-3">
              <button class="text-gray-400 hover:text-red-500">🗑️</button>
            </td>
          </tr>
        </tbody>
      </table>
    </section>
    
    <!-- API Keys -->
    <section class="card">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold">🔑 API Keys</h2>
        <button id="newKeyBtn" class="btn-primary">
          ➕ New Key
        </button>
      </div>
      
      <div class="space-y-2">
        <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
          <div>
            <div class="font-medium">Production Key</div>
            <div class="text-sm text-gray-500 font-mono">pk_live_****...****3f2a</div>
          </div>
          <div class="flex gap-2">
            <button class="text-sm text-blue-600 hover:underline">Copy</button>
            <button class="text-sm text-red-600 hover:underline">Revoke</button>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  // Invite user modal
  document.getElementById('inviteBtn')?.addEventListener('click', () => {
    const email = prompt('Enter email to invite:');
    if (email) {
      const tbody = document.getElementById('membersList');
      const row = document.createElement('tr');
      row.className = 'border-b';
      row.innerHTML = `
        <td class="py-3 flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-gray-400 text-white flex items-center justify-center">?</div>
          <div>
            <div class="font-medium">Pending</div>
            <div class="text-xs text-gray-500">${email}</div>
          </div>
        </td>
        <td class="py-3">
          <select class="input py-1">
            <option>Editor</option>
            <option>Viewer</option>
          </select>
        </td>
        <td class="py-3">
          <span class="text-yellow-600">Pending</span>
        </td>
        <td class="py-3">
          <button class="text-gray-400 hover:text-red-500">🗑️</button>
        </td>
      `;
      tbody.appendChild(row);
    }
  });
  
  // New API key
  document.getElementById('newKeyBtn')?.addEventListener('click', () => {
    const name = prompt('Name for this key:');
    if (name) {
      alert('API key created! Copy it now - you won\'t see it again.');
    }
  });
</script>

<style>
  .card {
    @apply bg-white rounded-xl p-6 shadow-sm border border-gray-200;
  }
  .input {
    @apply w-full px-3 py-2 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition;
  }
  .btn-primary {
    @apply px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition;
  }
  .border-b {
    @apply border-b border-gray-200;
  }
</style>
</Layout>