---
import AuthLayout from '../layouts/AuthLayout.astro';

const triggers = [
  { id: 'manual', name: '👆 Manual', desc: 'Run manually' },
  { id: 'schedule', name: '⏰ Schedule', desc: 'Run on schedule' },
  { id: 'webhook', name: '🪝 Webhook', desc: 'HTTP trigger' },
  { id: 'event', name: '⚡ Event', desc: 'On event' },
];

const actions = [
  { id: 'send_message', name: '💬 Send Message', desc: 'Send chat message' },
  { id: 'create_task', name: '✅ Create Task', desc: 'Create task' },
  { id: 'send_webhook', name: '🪝 Call Webhook', desc: 'Call HTTP endpoint' },
  { id: 'run_tool', name: '🔧 Run Tool', desc: 'Execute tool' },
  { id: 'summarize', name: '📝 Summarize', desc: 'Summarize conversation' },
];
---

<AuthLayout title="Workflows">
  <div class="max-w-4xl mx-auto py-8">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold">⚡ Workflows</h1>
      <button onclick="showCreate()" class="btn-primary">+ New Workflow</button>
    </div>
    
    <div class="grid grid-cols-3 gap-6">
    <div class="col-span-2">
      <div id="workflows-list" class="space-y-4">
        <div class="text-gray-500">No workflows yet.</div>
      </div>
    </div>
    <div>
      <h3 class="font-semibold mb-3">📋 Recent Runs</h3>
      <div id="runs-list" class="space-y-2 text-sm">
        <div class="text-gray-500">No runs yet.</div>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  let workflows = [];
  let runs = [];
  
  // Add run history
  const sampleRuns = [
    { id: 'r1', workflow: 'Daily Summary', status: 'success', duration: '2.3s', time: '2 min ago' },
    { id: 'r2', workflow: 'New Member Welcome', status: 'success', duration: '0.8s', time: '15 min ago' },
    { id: 'r3', workflow: 'Task Alert', status: 'failed', duration: '1.2s', time: '1 hour ago' },
  ];
  
  function renderRuns() {
    const list = document.getElementById('runs-list');
    if (!list) return;
    
    if (runs.length === 0 && workflows.length === 0) {
      list.innerHTML = sampleRuns.map(r => `
        <div class="flex items-center justify-between p-2 bg-white rounded">
          <div>
            <div class="font-medium">${r.workflow}</div>
            <div class="text-xs text-gray-500">${r.time}</div>
          </div>
          <span class="px-2 py-0.5 rounded text-xs ${r.status === 'success' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
            ${r.status === 'success' ? '✓' : '✗'}
          </span>
        </div>
      `).join('');
    } else {
      list.innerHTML = runs.map(r => `
        <div class="flex items-center justify-between p-2 bg-white rounded">
          <div>
            <div class="font-medium">${r.workflow}</div>
            <div class="text-xs text-gray-500">${r.time}</div>
          </div>
          <span class="px-2 py-0.5 rounded text-xs ${r.status === 'success' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}">
            ${r.status === 'success' ? '✓ ' + r.duration : '✗'}
          </span>
        </div>
      `).join('');
    }
  }
  
  // Built-in templates
  const templates = [
    { name: 'Daily Summary', trigger: 'schedule', action: 'summarize', description: 'Summarize conversations daily' },
    { name: 'New Member Welcome', trigger: 'event', action: 'send_message', description: 'Welcome new members' },
    { name: 'Task Created Alert', trigger: 'event', action: 'send_webhook', description: 'Notify on task creation' },
  ];
  
  function render() {
    const list = document.getElementById('workflows-list');
    if (!list) return;
    
    if (workflows.length === 0) {
      // Show templates
      list.innerHTML = `
        <h3 class="font-semibold mb-3">Quick Start Templates</h3>
        <div class="grid grid-cols-2 gap-3">
          ${templates.map(t => `
            <div class="bg-white p-4 rounded-xl border">
              <div class="font-medium">${t.name}</div>
              <div class="text-sm text-gray-500">${t.description}</div>
              <button onclick="useTemplate('${t.name}', '${t.trigger}', '${t.action}', '${t.description}')" 
                class="mt-2 text-sm text-blue-500">Use Template →</button>
            </div>
          `).join('')}
        </div>
      `;
    } else {
      list.innerHTML = workflows.map(w => `
        <div class="bg-white p-4 rounded-xl border flex items-center justify-between">
          <div>
            <div class="font-medium">${w.name}</div>
            <div class="text-sm text-gray-500">${w.description || w.trigger + ' → ' + w.action}</div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-sm ${w.enabled ? 'text-green-500' : 'text-gray-400'}">
              ${w.enabled ? '✓ Enabled' : '○ Disabled'}
            </span>
            <button onclick="toggleWorkflow('${w.id}')" class="px-2 py-1 text-sm border rounded">
              ${w.enabled ? 'Disable' : 'Enable'}
            </button>
            <button onclick="runWorkflow('${w.id}')" class="px-2 py-1 text-sm bg-blue-500 text-white rounded">
              Run
            </button>
            <button onclick="deleteWorkflow('${w.id}')" class="px-2 py-1 text-sm text-red-500">
              🗑️
            </button>
          </div>
        </div>
      `).join('');
    }
  }
  
  function useTemplate(name, trigger, action, description) {
    const w = {
      id: crypto.randomUUID(),
      name,
      trigger,
      action,
      description,
      enabled: true,
      created_at: new Date().toISOString(),
    };
    workflows.push(w);
    save();
    render();
  }
  
  function showCreate() {
    const name = prompt('Workflow name:');
    if (!name) return;
    
    const trigger = prompt('Trigger (manual/schedule/webhook/event):');
    const action = prompt('Action (send_message/create_task/send_webhook/run_tool/summarize):');
    const description = prompt('Description:');
    
    if (name && trigger && action) {
      workflows.push({
        id: crypto.randomUUID(),
        name,
        trigger,
        action,
        description,
        enabled: true,
        created_at: new Date().toISOString(),
      });
      save();
      render();
    }
  }
  
  function toggleWorkflow(id) {
    const w = workflows.find(w => w.id === id);
    if (w) {
      w.enabled = !w.enabled;
      save();
      render();
    }
  }
  
  function runWorkflow(id) {
    alert('Running workflow: ' + id);
  }
  
  function deleteWorkflow(id) {
    if (confirm('Delete workflow?')) {
      workflows = workflows.filter(w => w.id !== id);
      save();
      render();
    }
  }
  
  function save() {
    localStorage.setItem('workflows', JSON.stringify(workflows));
  }
  
  function load() {
    const saved = localStorage.getItem('workflows');
    if (saved) {
      workflows = JSON.parse(saved);
    }
    render();
  }
  
  // Init
  load();
  renderRuns();
</script>

<style>
  .btn-primary {
    @apply px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600;
  }
</style>