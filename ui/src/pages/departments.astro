---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Departments | Platform Agent">
  <div class="max-w-4xl mx-auto py-8">
    <h1 class="text-3xl font-bold mb-8">🏢 Departments</h1>
    
    <!-- Departments Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      
      <!-- Sales -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">💰</span>
          <div>
            <h3 class="text-lg font-semibold">Sales</h3>
            <p class="text-xs text-gray-500">Revenue & CRM</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Lead qualification</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Pipeline</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">3</span> members
        </div>
      </div>
      
      <!-- Support -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">🎧</span>
          <div>
            <h3 class="text-lg font-semibold">Support</h3>
            <p class="text-xs text-gray-500">Customer Success</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Ticket triage</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">KB search</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">5</span> members
        </div>
      </div>
      
      <!-- Engineering -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">⚙️</span>
          <div>
            <h3 class="text-lg font-semibold">Engineering</h3>
            <p class="text-xs text-gray-500">Development</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Code review</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Docs</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">8</span> members
        </div>
      </div>
      
      <!-- Marketing -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">📣</span>
          <div>
            <h3 class="text-lg font-semibold">Marketing</h3>
            <p class="text-xs text-gray-500">Growth</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Content</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Social</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">2</span> members
        </div>
      </div>
      
      <!-- HR -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">👥</span>
          <div>
            <h3 class="text-lg font-semibold">HR</h3>
            <p class="text-xs text-gray-500">People Operations</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Onboarding</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Policies</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">2</span> members
        </div>
      </div>
      
      <!-- Finance -->
      <div class="card">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-3xl">📊</span>
          <div>
            <h3 class="text-lg font-semibold">Finance</h3>
            <p class="text-xs text-gray-500">Accounting</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Expenses</span>
          <span class="px-2 py-1 bg-gray-100 rounded text-xs">Reports</span>
        </div>
        <div class="text-sm text-gray-600">
          <span class="font-semibold">2</span> members
        </div>
      </div>
    </div>
    
    <!-- Add Department -->
    <section class="card mb-6">
      <h2 class="text-lg font-semibold mb-4">➕ Add Department</h2>
      
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-sm font-medium mb-1">Name</label>
          <input type="text" id="deptName" class="input" placeholder="Department name" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Icon</label>
          <select id="deptIcon" class="input">
            <option value="💼">💼 Business</option>
            <option value="🔬">🔬 Research</option>
            <option value="📦">📦 Operations</option>
            <option value="🎨">🎨 Design</option>
            <option value="📱">📱 Product</option>
            <option value="⚖️">⚖️ Legal</option>
          </select>
        </div>
      </div>
      
      <div>
        <label class="block text-sm font-medium mb-1">Description</label>
        <textarea id="deptDesc" class="input" rows="2" placeholder="What does this department do?"></textarea>
      </div>
    </section>
    
    <!-- Department Stats -->
    <section class="card">
      <h2 class="text-lg font-semibold mb-4">📈 Overview</h2>
      
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="p-4 bg-gray-50 rounded-lg">
          <div class="text-2xl font-bold text-blue-600">6</div>
          <div class="text-sm text-gray-500">Departments</div>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <div class="text-2xl font-bold text-green-600">22</div>
          <div class="text-sm text-gray-500">Members</div>
        </div>
        <div class="p-4 bg-gray-50 rounded-lg">
          <div class="text-2xl font-bold text-purple-600">156</div>
          <div class="text-sm text-gray-500">Conversations</div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  document.getElementById('deptIcon')?.addEventListener('change', (e) => {
    // Visual feedback when icon changes
  });
</script>

<style>
  .card {
    @apply bg-white rounded-xl p-6 shadow-sm border border-gray-200;
  }
  .input {
    @apply w-full px-4 py-2 rounded-lg border border-gray-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20 outline-none transition;
  }
</style>
</Layout>