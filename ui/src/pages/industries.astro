---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Industries | Platform Agent">
  <div class="max-w-4xl mx-auto py-8">
    <h1 class="text-4xl font-bold mb-4 text-center">🏭 Industries</h1>
    <p class="text-xl text-gray-600 text-center mb-12">
      Platform Agent adapts to any industry with SurrealQL + your choice of LLM
    </p>
    
    <!-- Industry Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      
      <!-- Healthcare -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🏥</div>
        <h3 class="text-xl font-semibold mb-2">Healthcare</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Patient intake automation</li>
          <li>• Medical records Q&A</li>
          <li>• Appointment scheduling</li>
          <li>• Drug interaction lookup</li>
        </ul>
      </div>
      
      <!-- Finance -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🏦</div>
        <h3 class="text-xl font-semibold mb-2">Finance</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Investment research</li>
          <li>• Fraud detection support</li>
          <li>• Customer support</li>
          <li>• Compliance Q&A</li>
        </ul>
      </div>
      
      <!-- Legal -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">⚖️</div>
        <h3 class="text-xl font-semibold mb-2">Legal</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Contract analysis</li>
          <li>• Case law search</li>
          <li>• Document drafting</li>
          <li>• Client intake</li>
        </ul>
      </div>
      
      <!-- E-commerce -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🛒</div>
        <h3 class="text-xl font-semibold mb-2">E-commerce</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Product recommendations</li>
          <li>• Order status tracking</li>
          <li>• Returns processing</li>
          <li>• Inventory Q&A</li>
        </ul>
      </div>
      
      <!-- Education -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">📚</div>
        <h3 class="text-xl font-semibold mb-2">Education</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Tutoring assistant</li>
          <li>• Assignment help</li>
          <li>• Progress tracking</li>
          <li>• Parent communication</li>
        </ul>
      </div>
      
      <!-- Real Estate -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🏠</div>
        <h3 class="text-xl font-semibold mb-2">Real Estate</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Property search</li>
          <li>• Tour scheduling</li>
          <li>• Market analysis</li>
          <li>• Document prep</li>
        </ul>
      </div>
      
      <!-- SaaS -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">☁️</div>
        <h3 class="text-xl font-semibold mb-2">SaaS</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Support automation</li>
          <li>• Feature discovery</li>
          <li>• Onboarding</li>
          <li>• Documentation</li>
        </ul>
      </div>
      
      <!-- Manufacturing -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🏗️</div>
        <h3 class="text-xl font-semibold mb-2">Manufacturing</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Quality control</li>
          <li>• Supply chain Q&A</li>
          <li>• SOP guidance</li>
          <li>• Safety compliance</li>
        </ul>
      </div>
      
      <!-- Government -->
      <div class="card hover:shadow-lg transition">
        <div class="text-4xl mb-3">🏛️</div>
        <h3 class="text-xl font-semibold mb-2">Government</h3>
        <ul class="text-sm text-gray-600 space-y-2">
          <li>• Citizen services</li>
          <li>• Permit processing</li>
          <li>• Policy lookup</li>
          <li>• FOIA requests</li>
        </ul>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="card mt-12 text-center bg-gradient-to-r from-blue-500 to-purple-600 text-white">
      <h2 class="text-2xl font-bold mb-2">Ready to get started?</h2>
      <p class="mb-4">Deploy your industry-specific agent in minutes</p>
      <a href="/signup" class="inline-block px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition">
        🚀 Start Free
      </a>
    </div>
  </div>
</Layout>

<style>
  .card {
    @apply bg-white rounded-xl p-6 shadow-sm border border-gray-200;
  }
</style>
</Layout>