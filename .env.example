# Platform Agent Environment Variables

# Copy this file to .env and fill in your values

# =============================================================================
# SurrealDB Configuration
# =============================================================================
# WebSocket URL for SurrealDB connection
SURREALDB_URL=ws://localhost:8000/rpc
# Database namespace
SURREALDB_NAMESPACE=platform
# Database name
SURREALDB_DATABASE=agent
# Authentication username
SURREALDB_USERNAME=root
# Authentication password
SURREALDB_PASSWORD=root

# =============================================================================
# LLM (Large Language Model) Configuration
# =============================================================================
# Model to use (gpt-4o-mini, gpt-4, claude-3-opus, etc.)
LLM_MODEL=gpt-4o-mini
# API key for LLM provider (OpenAI, Anthropic, etc.)
LLM_API_KEY=sk-your-api-key-here
# Base URL for LLM API (for custom endpoints)
LLM_BASE_URL=

# =============================================================================
# SurrealDB AI Agents Features
# =============================================================================
# Enable MCP (Model Context Protocol)
ENABLE_MCP=false
# Enable RAG (Retrieval Augmented Generation)
ENABLE_RAG=true
# Enable Graph RAG
ENABLE_GRAPH_RAG=true
# Enable live queries for real-time reactivity
ENABLE_LIVE_QUERIES=false
# Session timeout in seconds
SESSION_TIMEOUT=3600


# =============================================================================
# Agent Prompts (Optional)
# =============================================================================
# Custom system prompt
AGENT_SYSTEM_PROMPT=
# Welcome message for new conversations
AGENT_WELCOME_MESSAGE=
# Error message
AGENT_ERROR_MESSAGE=
# Sampling temperature (0.0 to 1.0)
LLM_TEMPERATURE=0.7
# Maximum tokens in response
LLM_MAX_TOKENS=2048

# =============================================================================
# Agent Configuration
# =============================================================================
# Maximum number of memories to store
AGENT_MEMORY_LIMIT=100
# Number of results for vector search
AGENT_VECTOR_SEARCH_LIMIT=5
# Maximum iterations per task
AGENT_MAX_ITERATIONS=10
# Enable verbose logging
AGENT_VERBOSE=false

# =============================================================================
# Optional: External Services
# =============================================================================
# For web search (Tavily, Serper, etc.)
TAVILY_API_KEY=
# For web fetch
BROWSER_API_KEY=